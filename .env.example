# OpenClaw Environment Variables for Railway

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT-5.2)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=xxx

# Bankr API Key
BANKR_API_KEY=

# OpenClaw Gateway Settings
OPENCLAW_PORT=18789
OPENCLAW_MODE=production
OPENCLAW_BIND=0.0.0.0

# Railway specific
PORT=18789
NODE_ENV=production
