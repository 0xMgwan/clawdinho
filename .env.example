# OpenClaw Environment Variables for Railway Deployment

# Anthropic API Key
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (for GPT-5.2)
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=xxx

# Bankr API Key
BANKR_API_KEY=

# Required for Railway
SETUP_PASSWORD=your-chosen-strong-password
PORT=8080

# Persistence & Stability (recommended)
OPENCLAW_STATE_DIR=/data/openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_GATEWAY_TOKEN=your-long-random-secret-string

# OpenClaw Gateway Settings
OPENCLAW_PORT=18789
OPENCLAW_MODE=production
OPENCLAW_BIND=0.0.0.0

# Railway specific
NODE_ENV=production
