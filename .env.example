# OpenClaw Environment Variables for Railway Deployment

# OpenAI API Key (for GPT-5.2 primary) - REQUIRED
OPENAI_API_KEY=your_openai_api_key_here

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=

# Bankr API Key
BANKR_API_KEY=

# Simmer API Key
SIMMER_API_KEY=

# Required for Railway
SETUP_PASSWORD=
PORT=8080

# Persistence & Stability (recommended)
OPENCLAW_STATE_DIR=/data/openclaw
OPENCLAW_WORKSPACE_DIR=/data/workspace
OPENCLAW_GATEWAY_TOKEN=

# --- Google Suite (Gmail + Calendar) ---
# Required to refresh the Google OAuth refresh token stored in auth-profiles.json
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional override if you are not using the default OpenClaw agent id
# OPENCLAW_AGENT_ID=main

# OpenClaw Gateway Settings
OPENCLAW_PORT=18789
OPENCLAW_MODE=production
OPENCLAW_BIND=0.0.0.0
NODE_ENV=production
